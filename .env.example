# Supabase (browser + server)
# URL = só o domínio do projeto (Settings → API → Project URL). Não uses .../rest/v1 nem links do dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Só servidor — checklist sem login (bypass RLS)
# Settings → API → service_role (nunca exponhas no cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
